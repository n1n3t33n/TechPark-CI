<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_it_affectation_tree" model="ir.ui.view">
        <field name="name">it.affectation.list</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <list string="Historique des affectations"
                  decoration-muted="active_line==False">
                <field name="equipement_id"/>
                <field name="employe_id"/>
                <field name="departement_id"/>
                <field name="date_affectation"/>
                <field name="date_retour"/>
                <field name="motif"/>
                <field name="active_line"/>
            </list>
        </field>
    </record>

    <record id="view_it_affectation_form" model="ir.ui.view">
        <field name="name">it.affectation.form</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <form string="Affectation">
                <sheet>
                    <group>
                        <group string="Équipement">
                            <field name="equipement_id"/>
                        </group>
                        <group string="Affecté à">
                            <field name="employe_id"/>
                            <field name="departement_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Période">
                            <field name="date_affectation"/>
                            <field name="date_retour"/>
                            <field name="active_line"/>
                        </group>
                    </group>
                    <group string="Motif">
                        <field name="motif" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_it_affectation_search" model="ir.ui.view">
        <field name="name">it.affectation.search</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <search string="Rechercher une affectation">
                <field name="employe_id"/>
                <field name="equipement_id"/>
                <field name="departement_id"/>
                <filter string="Actives seulement" name="actives" domain="[('active_line','=',True)]"/>
                <group expand="0" string="Regrouper par">
                    <filter string="Employé"     name="by_employe"     context="{'group_by':'employe_id'}"/>
                    <filter string="Département" name="by_departement" context="{'group_by':'departement_id'}"/>
                    <filter string="Équipement"  name="by_equipement"  context="{'group_by':'equipement_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_it_affectation" model="ir.actions.act_window">
        <field name="name">Historique des affectations</field>
        <field name="res_model">it.affectation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_it_affectation_search"/>
    </record>

</odoo>