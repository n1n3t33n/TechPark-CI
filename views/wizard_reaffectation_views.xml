<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_reaffectation_form" model="ir.ui.view">
        <field name="name">wizard.reaffectation.form</field>
        <field name="model">wizard.reaffectation</field>
        <field name="arch" type="xml">
            <form string="Réaffecter l'équipement">
                <sheet>
                    <group string="Équipement concerné">
                        <field name="equipement_id" readonly="1"/>
                    </group>
                    <group>
                        <group string="Affectation actuelle">
                            <field name="ancien_employe_id"     readonly="1"/>
                            <field name="ancien_departement_id" readonly="1"/>
                        </group>
                        <group string="Nouvelle affectation">
                            <field name="nouvel_employe_id"/>
                            <field name="nouveau_departement_id"/>
                            <field name="date_reaffectation"/>
                        </group>
                    </group>
                    <group string="Motif obligatoire">
                        <field name="motif" nolabel="1"
                               placeholder="Expliquez la raison de cette réaffectation..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirmer" string="Confirmer la réaffectation"
                            type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_reaffectation" model="ir.actions.act_window">
        <field name="name">Réaffecter l'équipement</field>
        <field name="res_model">wizard.reaffectation</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_it_equipement"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>