<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_renouvellement_form" model="ir.ui.view">
        <field name="name">wizard.renouvellement.form</field>
        <field name="model">wizard.renouvellement</field>
        <field name="arch" type="xml">
            <form string="Renouveler le contrat">
                <sheet>
                    <group>
                        <group string="Contrat concerné">
                            <field name="contrat_id"       readonly="1"/>
                            <field name="ancienne_date_fin" readonly="1"/>
                        </group>
                        <group string="Nouveau contrat">
                            <field name="nouvelle_date_fin"/>
                            <field name="nouveau_montant"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"
                               placeholder="Notes sur ce renouvellement..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirmer" string="Confirmer le renouvellement"
                            type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_renouvellement" model="ir.actions.act_window">
        <field name="name">Renouveler le contrat</field>
        <field name="res_model">wizard.renouvellement</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_it_contrat"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>