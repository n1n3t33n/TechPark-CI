<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── VUE FORM ─────────────────────────────────────────────────────── -->
    <record id="view_it_equipement_form" model="ir.ui.view">
        <field name="name">it.equipement.form</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <form string="Équipement">
                <header>
                    <button name="action_affecter"
                            string="Affecter"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'brouillon'"/>
                    <button name="action_mettre_en_location"
                            string="Mettre en location"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ('brouillon','affecte')"/>
                    <button name="action_terminer_location"
                            string="Fin de location"
                            type="object"
                            invisible="state != 'location'"/>
                    <button name="action_mettre_en_maintenance"
                            string="Mettre en maintenance"
                            type="object"
                            invisible="state not in ('brouillon','affecte','location')"/>
                    <button name="action_retirer"
                            string="Retirer du parc"
                            type="object"
                            invisible="state == 'retire'"/>
                    <button name="action_remettre_en_brouillon"
                            string="Remettre en brouillon"
                            type="object"
                            invisible="state == 'brouillon'"/>
                    <button name="action_export_inventaire_excel"
                            string="Export inventaire Excel"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_export_couts_maintenance_excel"
                            string="Export coûts Excel"
                            type="object"
                            class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="brouillon,affecte,location,maintenance,retire"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nom de l'équipement"/>
                        </h1>
                        <h3>
                            <field name="reference" readonly="1"/>
                        </h3>
                    </div>

                    <field name="famille" invisible="1"/>
                    <group>
                        <group string="Identification">
                            <field name="categorie"/>
                            <field name="marque"/>
                            <field name="modele"/>
                            <field name="numero_serie"/>
                        </group>
                        <group string="Client / Site">
                            <field name="partner_id"/>
                            <field name="site_id"/>
                            <field name="employe_id"/>
                            <field name="departement_id"/>
                        </group>
                    </group>

                    <group string="Caractéristiques techniques">
                        <group invisible="famille != 'informatique'">
                            <field name="cpu"/>
                            <field name="ram_go"/>
                            <field name="stockage_go"/>
                            <field name="type_stockage"/>
                            <field name="systeme_exploitation"/>
                        </group>
                        <group invisible="famille != 'reseau'">
                            <field name="adresse_ip"/>
                            <field name="adresse_mac"/>
                            <field name="nb_ports"/>
                        </group>
                        <group invisible="categorie != 'ecran'">
                            <field name="taille_ecran"/>
                        </group>
                        <field name="specifications" colspan="2"
                               placeholder="Autres caractéristiques (carte graphique, batterie, ports...)"/>
                    </group>

                    <group>
                        <group string="Informations financières">
                            <field name="fournisseur_id"/>
                            <field name="date_achat"/>
                            <field name="valeur_achat"/>
                            <field name="sale_order_id"/>
                            <field name="stock_picking_id"/>
                        </group>
                        <group string="Garantie">
                            <field name="date_fin_garantie"/>
                            <field name="jours_garantie_restants"/>
                            <field name="garantie_expiree"/>
                        </group>
                    </group>

                    <group string="Location"
                           invisible="state != 'location' and not locataire_id">
                        <group>
                            <field name="locataire_id"/>
                            <field name="loyer_mensuel"/>
                        </group>
                        <group>
                            <field name="date_debut_location"/>
                            <field name="date_fin_location"/>
                            <field name="jours_avant_fin_location"/>
                            <field name="location_bientot_finie"/>
                        </group>
                    </group>

                    <group string="Notes / Description">
                        <field name="description" nolabel="1"/>
                    </group>

                    <notebook>

                        <page string="Interventions" name="interventions">
                            <field name="intervention_ids">
                                <list string="Interventions"
                                      decoration-info="state=='planifie'"
                                      decoration-success="state=='termine'"
                                      decoration-danger="state=='annule'">
                                    <field name="name"/>
                                    <field name="type_intervention"/>
                                    <field name="technicien_id"/>
                                    <field name="date_debut"/>
                                    <field name="date_fin"/>
                                    <field name="duree_heures"/>
                                    <field name="cout"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Historique des affectations" name="affectations">
                            <field name="affectation_ids">
                                <list string="Affectations" editable="bottom">
                                    <field name="employe_id"/>
                                    <field name="departement_id"/>
                                    <field name="localisation"/>
                                    <field name="date_affectation"/>
                                    <field name="date_retour"/>
                                    <field name="motif"/>
                                    <field name="active_line"/>
                                </list>
                            </field>
                        </page>

                        <page string="Contrats" name="contrats">
                            <field name="contrat_ids">
                                <list string="Contrats"
                                      decoration-danger="expire==True">
                                    <field name="name"/>
                                    <field name="type_contrat"/>
                                    <field name="fournisseur_id"/>
                                    <field name="date_debut"/>
                                    <field name="date_fin"/>
                                    <field name="jours_restants"/>
                                    <field name="expire"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Tickets" name="tickets">
                            <field name="ticket_ids">
                                <list string="Tickets">
                                    <field name="name"/>
                                    <field name="subject"/>
                                    <field name="priority"/>
                                    <field name="technicien_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Licences" name="licenses">
                            <field name="license_ids">
                                <list string="Licences">
                                    <field name="name"/>
                                    <field name="license_type"/>
                                    <field name="seat_count"/>
                                    <field name="date_expiration"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Statistiques" name="stats">
                            <group>
                                <field name="nb_interventions"/>
                                <field name="cout_total_maintenance"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── VUE TREE ──────────────────────────────────────────────────────── -->
    <record id="view_it_equipement_tree" model="ir.ui.view">
        <field name="name">it.equipement.tree</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <list string="Équipements"
                  decoration-muted="state=='retire'"
                  decoration-danger="garantie_expiree==True"
                  decoration-warning="jours_garantie_restants &lt; 30 and not garantie_expiree">
                <field name="reference"/>
                <field name="name"/>
                <field name="categorie"/>
                <field name="marque"/>
                <field name="modele"/>
                <field name="numero_serie" optional="show"/>
                <field name="cpu" optional="hide"/>
                <field name="ram_go" optional="hide"/>
                <field name="stockage_go" optional="hide"/>
                <field name="partner_id" optional="show"/>
                <field name="site_id" optional="show"/>
                <field name="employe_id" optional="show"/>
                <field name="departement_id" optional="hide"/>
                <field name="locataire_id" optional="hide"/>
                <field name="date_fin_garantie" optional="show"/>
                <field name="jours_garantie_restants" optional="hide"/>
                <field name="garantie_expiree" optional="hide"/>
                <field name="nb_interventions" optional="hide"/>
                <field name="cout_total_maintenance" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state=='brouillon'"
                       decoration-success="state=='affecte'"
                       decoration-primary="state=='location'"
                       decoration-warning="state=='maintenance'"
                       decoration-danger="state=='retire'"/>
            </list>
        </field>
    </record>

    <!-- ─── VUE KANBAN ────────────────────────────────────────────────────── -->
    <record id="view_it_equipement_kanban" model="ir.ui.view">
        <field name="name">it.equipement.kanban</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="categorie"/>
                <field name="marque"/>
                <field name="employe_id"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="garantie_expiree"/>
                <templates>
                    <t t-name="card">
                        <strong><field name="name"/></strong>
                        <div><field name="categorie"/> — <field name="marque"/></div>
                        <div t-if="record.partner_id.raw_value">🏢 <field name="partner_id"/></div>
                        <div t-if="record.employe_id.raw_value">👤 <field name="employe_id"/></div>
                        <div t-if="record.garantie_expiree.raw_value"
                             class="text-danger">⚠️ Garantie expirée</div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── VUE SEARCH ────────────────────────────────────────────────────── -->
    <record id="view_it_equipement_search" model="ir.ui.view">
        <field name="name">it.equipement.search</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <search string="Rechercher un équipement">
                <field name="name" string="Nom"/>
                <field name="reference"/>
                <field name="numero_serie"/>
                <field name="partner_id"/>
                <field name="site_id"/>
                <field name="employe_id"/>
                <field name="departement_id"/>
                <separator/>
                <filter string="Brouillon"     name="brouillon"   domain="[('state','=','brouillon')]"/>
                <filter string="Affectés"       name="affectes"    domain="[('state','=','affecte')]"/>
                <filter string="En location"    name="location"    domain="[('state','=','location')]"/>
                <filter string="En maintenance" name="maintenance" domain="[('state','=','maintenance')]"/>
                <filter string="Retirés"        name="retires"     domain="[('state','=','retire')]"/>
                <separator/>
                <filter string="Garantie expirée"  name="garantie_expiree"  domain="[('garantie_expiree','=',True)]"/>
                <filter string="Garantie &lt; 30j" name="garantie_critique" domain="[('jours_garantie_restants','&lt;',30),('garantie_expiree','=',False)]"/>
                <filter string="Fin de location proche" name="location_fin" domain="[('location_bientot_finie','=',True)]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter string="Catégorie"   name="by_categorie"   context="{'group_by':'categorie'}"/>
                    <filter string="Client"       name="by_partner"     context="{'group_by':'partner_id'}"/>
                    <filter string="Site client"  name="by_site"        context="{'group_by':'site_id'}"/>
                    <filter string="Département" name="by_departement" context="{'group_by':'departement_id'}"/>
                    <filter string="État"         name="by_state"       context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── ACTION ───────────────────────────────────────────────────────── -->
    <record id="action_it_equipement" model="ir.actions.act_window">
        <field name="name">Équipements</field>
        <field name="res_model">it.equipement</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_it_equipement_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre premier équipement !
            </p>
        </field>
    </record>

</odoo>
