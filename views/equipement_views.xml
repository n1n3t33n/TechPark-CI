<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── VUE FORM ─────────────────────────────────────────────────────── -->
    <record id="view_it_equipement_form" model="ir.ui.view">
        <field name="name">it.equipement.form</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <form string="Équipement">
                <header>
                    <button name="action_affecter"
                            string="Affecter"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'brouillon'"/>
                    <button name="action_mettre_en_maintenance"
                            string="Mettre en maintenance"
                            type="object"
                            invisible="state not in ('brouillon','affecte')"/>
                    <button name="action_retirer"
                            string="Retirer du parc"
                            type="object"
                            invisible="state == 'retire'"/>
                    <button name="action_remettre_en_brouillon"
                            string="Remettre en brouillon"
                            type="object"
                            invisible="state == 'brouillon'"/>
                    <button name="action_export_inventaire_excel"
                            string="Export inventaire Excel"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_export_couts_maintenance_excel"
                            string="Export coûts Excel"
                            type="object"
                            class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="brouillon,affecte,maintenance,retire"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nom de l'équipement"/>
                        </h1>
                        <h3>
                            <field name="reference" readonly="1"/>
                        </h3>
                    </div>

                    <group>
                        <group string="Identification">
                            <field name="categorie"/>
                            <field name="marque"/>
                            <field name="modele"/>
                            <field name="numero_serie"/>
                            <field name="site"/>
                            <field name="localisation"/>
                        </group>
                        <group string="Affectation">
                            <field name="employe_id"/>
                            <field name="departement_id"/>
                        </group>
                    </group>

                    <group>
                        <group string="Informations financières">
                            <field name="fournisseur_id"/>
                            <field name="date_achat"/>
                            <field name="valeur_achat"/>
                        </group>
                        <group string="Garantie">
                            <field name="date_fin_garantie"/>
                            <field name="jours_garantie_restants"/>
                            <field name="garantie_expiree"/>
                        </group>
                    </group>

                    <group string="Description technique">
                        <field name="description" nolabel="1"/>
                    </group>

                    <notebook>

                        <page string="Interventions" name="interventions">
                            <field name="intervention_ids">
                                <list string="Interventions"
                                      decoration-info="state=='planifie'"
                                      decoration-success="state=='termine'"
                                      decoration-danger="state=='annule'">
                                    <field name="name"/>
                                    <field name="type_intervention"/>
                                    <field name="technicien_id"/>
                                    <field name="date_debut"/>
                                    <field name="date_fin"/>
                                    <field name="duree_heures"/>
                                    <field name="cout"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Historique des affectations" name="affectations">
                            <field name="affectation_ids">
                                <list string="Affectations">
                                    <field name="employe_id"/>
                                    <field name="departement_id"/>
                                    <field name="date_affectation"/>
                                    <field name="date_retour"/>
                                    <field name="motif"/>
                                    <field name="active_line"/>
                                </list>
                            </field>
                        </page>

                        <page string="Contrats" name="contrats">
                            <field name="contrat_ids">
                                <list string="Contrats"
                                      decoration-danger="expire==True">
                                    <field name="name"/>
                                    <field name="type_contrat"/>
                                    <field name="fournisseur_id"/>
                                    <field name="date_debut"/>
                                    <field name="date_fin"/>
                                    <field name="jours_restants"/>
                                    <field name="expire"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Statistiques" name="stats">
                            <group>
                                <field name="nb_interventions"/>
                                <field name="cout_total_maintenance"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── VUE TREE ──────────────────────────────────────────────────────── -->
    <record id="view_it_equipement_tree" model="ir.ui.view">
        <field name="name">it.equipement.tree</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <list string="Équipements"
                  decoration-muted="state=='retire'"
                  decoration-danger="garantie_expiree==True"
                  decoration-warning="jours_garantie_restants &lt; 30 and not garantie_expiree">
                <field name="reference"/>
                <field name="name"/>
                <field name="categorie"/>
                <field name="marque"/>
                <field name="modele"/>
                <field name="numero_serie"/>
                <field name="site"/>
                <field name="employe_id"/>
                <field name="departement_id"/>
                <field name="date_fin_garantie"/>
                <field name="jours_garantie_restants" optional="show"/>
                <field name="garantie_expiree" optional="hide"/>
                <field name="nb_interventions" optional="show"/>
                <field name="cout_total_maintenance" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state=='brouillon'"
                       decoration-success="state=='affecte'"
                       decoration-warning="state=='maintenance'"
                       decoration-danger="state=='retire'"/>
            </list>
        </field>
    </record>

    <!-- ─── VUE KANBAN ────────────────────────────────────────────────────── -->
    <record id="view_it_equipement_kanban" model="ir.ui.view">
        <field name="name">it.equipement.kanban</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="categorie"/>
                <field name="marque"/>
                <field name="employe_id"/>
                <field name="state"/>
                <field name="garantie_expiree"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong><field name="name"/></strong>
                                <div><field name="categorie"/> — <field name="marque"/></div>
                                <div>👤 <field name="employe_id"/></div>
                                <div t-if="record.garantie_expiree.raw_value"
                                     class="text-danger">⚠️ Garantie expirée</div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── VUE SEARCH ────────────────────────────────────────────────────── -->
    <record id="view_it_equipement_search" model="ir.ui.view">
        <field name="name">it.equipement.search</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <search string="Rechercher un équipement">
                <field name="name" string="Nom"/>
                <field name="reference"/>
                <field name="numero_serie"/>
                <field name="employe_id"/>
                <field name="departement_id"/>
                <separator/>
                <filter string="Brouillon"     name="brouillon"   domain="[('state','=','brouillon')]"/>
                <filter string="Affectés"       name="affectes"    domain="[('state','=','affecte')]"/>
                <filter string="En maintenance" name="maintenance" domain="[('state','=','maintenance')]"/>
                <filter string="Retirés"        name="retires"     domain="[('state','=','retire')]"/>
                <separator/>
                <filter string="Garantie expirée"  name="garantie_expiree"  domain="[('garantie_expiree','=',True)]"/>
                <filter string="Garantie &lt; 30j" name="garantie_critique" domain="[('jours_garantie_restants','&lt;',30),('garantie_expiree','=',False)]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter string="Catégorie"   name="by_categorie"   context="{'group_by':'categorie'}"/>
                    <filter string="Site"         name="by_site"        context="{'group_by':'site'}"/>
                    <filter string="Département" name="by_departement" context="{'group_by':'departement_id'}"/>
                    <filter string="État"         name="by_state"       context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── ACTION ───────────────────────────────────────────────────────── -->
    <record id="action_it_equipement" model="ir.actions.act_window">
        <field name="name">Équipements</field>
        <field name="res_model">it.equipement</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_it_equipement_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre premier équipement !
            </p>
        </field>
    </record>

</odoo>