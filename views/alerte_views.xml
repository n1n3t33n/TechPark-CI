<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_it_alerte_tree" model="ir.ui.view">
        <field name="name">it.alerte.list</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <list string="Alertes"
                  decoration-danger="state=='nouvelle'"
                  decoration-muted="state=='traitee'">
                <field name="name"/>
                <field name="type_alerte"/>
                <field name="equipement_id"/>
                <field name="contrat_id"/>
                <field name="license_id" optional="show"/>
                <field name="date_echeance"/>
                <field name="jours_restants"/>
                <field name="state" widget="badge"
                       decoration-danger="state=='nouvelle'"
                       decoration-warning="state=='vue'"
                       decoration-success="state=='traitee'"/>
            </list>
        </field>
    </record>

    <record id="view_it_alerte_form" model="ir.ui.view">
        <field name="name">it.alerte.form</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <form string="Alerte">
                <header>
                    <button name="action_marquer_vue"     string="Marquer comme vue"
                            type="object" invisible="state != 'nouvelle'"/>
                    <button name="action_marquer_traitee" string="Marquer comme traitée"
                            type="object" invisible="state == 'traitee'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Alerte">
                            <field name="name"/>
                            <field name="type_alerte"/>
                            <field name="date_echeance"/>
                            <field name="jours_restants"/>
                        </group>
                        <group string="Concerné">
                            <field name="equipement_id"/>
                            <field name="contrat_id"/>
                            <field name="license_id"/>
                        </group>
                    </group>
                    <group string="Message">
                        <field name="message" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_it_alerte_search" model="ir.ui.view">
        <field name="name">it.alerte.search</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <search string="Rechercher une alerte">
                <field name="name"/>
                <field name="equipement_id"/>
                <filter string="Nouvelles"    name="nouvelle"    domain="[('state','=','nouvelle')]"/>
                <filter string="Non traitées" name="non_traitee" domain="[('state','!=','traitee')]"/>
                <filter string="Garantie"     name="garantie"    domain="[('type_alerte','=','garantie')]"/>
                <filter string="Contrat"      name="contrat"     domain="[('type_alerte','=','contrat')]"/>
                <filter string="Licence"      name="licence"     domain="[('type_alerte','=','licence')]"/>
                <filter string="Location"     name="location"    domain="[('type_alerte','=','location')]"/>
                <group expand="0" string="Regrouper par">
                    <filter string="Type"  name="by_type"  context="{'group_by':'type_alerte'}"/>
                    <filter string="État"  name="by_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_it_alerte" model="ir.actions.act_window">
        <field name="name">Alertes</field>
        <field name="res_model">it.alerte</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_it_alerte_search"/>
    </record>

</odoo>