<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_license_list" model="ir.ui.view">
        <field name="name">it.license.list</field>
        <field name="model">it.license</field>
        <field name="arch" type="xml">
            <list string="Licences"
                  decoration-warning="state == 'expiring'"
                  decoration-danger="state == 'expired'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="equipement_id"/>
                <field name="license_type"/>
                <field name="seat_count"/>
                <field name="date_expiration"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_it_license_form" model="ir.ui.view">
        <field name="name">it.license.form</field>
        <field name="model">it.license</field>
        <field name="arch" type="xml">
            <form string="Licence">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="equipement_id"/>
                            <field name="license_key"/>
                        </group>
                        <group>
                            <field name="license_type"/>
                            <field name="seat_count"/>
                            <field name="date_start"/>
                            <field name="date_expiration"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <field name="notes" nolabel="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_it_license_search" model="ir.ui.view">
        <field name="name">it.license.search</field>
        <field name="model">it.license</field>
        <field name="arch" type="xml">
            <search string="Rechercher une licence">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="equipement_id"/>
                <filter string="Expire bientôt" name="expiring" domain="[('state','=','expiring')]"/>
                <filter string="Expirées" name="expired" domain="[('state','=','expired')]"/>
                <group expand="0" string="Regrouper par">
                    <filter string="Client" name="by_partner" context="{'group_by':'partner_id'}"/>
                    <filter string="Machine" name="by_equipment" context="{'group_by':'equipement_id'}"/>
                    <filter string="État" name="by_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_it_license" model="ir.actions.act_window">
        <field name="name">Licences</field>
        <field name="res_model">it.license</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_it_license_search"/>
    </record>
</odoo>

