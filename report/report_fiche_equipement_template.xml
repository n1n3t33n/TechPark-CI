<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="template_fiche_equipement">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="doc">
<t t-call="web.external_layout">
<div class="page">

    <div class="row mb-4">
        <div class="col-6">
            <h2 class="text-primary">Fiche Équipement</h2>
            <h3><t t-esc="doc.name"/></h3>
            <span class="badge rounded-pill text-bg-info">
                <t t-esc="doc.reference"/>
            </span>
        </div>
        <div class="col-6 text-end">
            <span class="badge"
                  t-attf-style="background-color: #{'#28a745' if doc.state == 'affecte' else '#ffc107' if doc.state == 'maintenance' else '#dc3545' if doc.state == 'retire' else '#6c757d'}; color:white; font-size:14px; padding:8px 16px;">
                <t t-esc="dict(brouillon='Brouillon', affecte='Affecté', maintenance='En maintenance', retire='Retiré').get(doc.state, doc.state)"/>
            </span>
        </div>
    </div>

    <hr/>

    <h4 class="text-primary mt-3">Identification</h4>
    <table class="table table-sm table-bordered">
        <tr>
            <th style="width:30%; background:#f8f9fa;">Catégorie</th>
            <td><t t-esc="dict(doc._fields['categorie'].selection).get(doc.categorie, doc.categorie or 'N/A')"/></td>
            <th style="width:30%; background:#f8f9fa;">Marque / Modèle</th>
            <td><t t-esc="(doc.marque or '') + ' ' + (doc.modele or '')"/></td>
        </tr>
        <tr>
            <th style="background:#f8f9fa;">Numéro de série</th>
            <td><t t-esc="doc.numero_serie or 'N/A'"/></td>
            <th style="background:#f8f9fa;">Client / Site</th>
            <td><t t-esc="' / '.join([x for x in [doc.partner_id.name, doc.site_id.name] if x]) or 'N/A'"/></td>
        </tr>
    </table>

    <h4 class="text-primary mt-3">Affectation</h4>
    <table class="table table-sm table-bordered">
        <tr>
            <th style="width:30%; background:#f8f9fa;">Employé affecté</th>
            <td><t t-esc="doc.employe_id.name if doc.employe_id else 'Non affecté'"/></td>
            <th style="width:30%; background:#f8f9fa;">Département</th>
            <td><t t-esc="doc.departement_id.name if doc.departement_id else 'N/A'"/></td>
        </tr>
    </table>

    <h4 class="text-primary mt-3">Finances et Garantie</h4>
    <table class="table table-sm table-bordered">
        <tr>
            <th style="width:30%; background:#f8f9fa;">Date d'achat</th>
            <td><t t-esc="str(doc.date_achat) if doc.date_achat else 'N/A'"/></td>
            <th style="width:30%; background:#f8f9fa;">Valeur d'achat</th>
            <td><t t-esc="'{:,.0f}'.format(doc.valeur_achat)"/> FCFA</td>
        </tr>
        <tr>
            <th style="background:#f8f9fa;">Fournisseur</th>
            <td><t t-esc="doc.fournisseur_id.name if doc.fournisseur_id else 'N/A'"/></td>
            <th style="background:#f8f9fa;">Fin de garantie</th>
            <td t-attf-style="color: #{'red' if doc.garantie_expiree else 'darkorange' if doc.date_fin_garantie and doc.jours_garantie_restants &lt; 90 else 'black'};">
                <t t-esc="str(doc.date_fin_garantie) if doc.date_fin_garantie else 'N/A'"/>
                <t t-if="doc.garantie_expiree"> [!] EXPIREE</t>
                <t t-elif="doc.date_fin_garantie and doc.jours_garantie_restants">
                    (<t t-esc="doc.jours_garantie_restants"/> j restants)
                </t>
            </td>
        </tr>
    </table>

    <h4 class="text-primary mt-3">Maintenance</h4>
    <table class="table table-sm table-bordered">
        <tr>
            <th style="width:40%; background:#f8f9fa;">Nombre d'interventions</th>
            <td><t t-esc="doc.nb_interventions"/></td>
            <th style="width:30%; background:#f8f9fa;">Coût total maintenance</th>
            <td><t t-esc="'{:,.0f}'.format(doc.cout_total_maintenance)"/> FCFA</td>
        </tr>
    </table>

    <t t-if="doc.intervention_ids">
        <h4 class="text-primary mt-3">Historique des interventions</h4>
        <table class="table table-sm table-bordered table-striped">
            <thead style="background:#343a40; color:white;">
                <tr>
                    <th>Objet</th>
                    <th>Type</th>
                    <th>Technicien</th>
                    <th>Date début</th>
                    <th>Durée (h)</th>
                    <th>Coût (FCFA)</th>
                    <th>État</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="doc.intervention_ids" t-as="interv">
                <tr>
                    <td><t t-esc="interv.name"/></td>
                    <td><t t-esc="dict(corrective='Corrective', preventive='Préventive').get(interv.type_intervention, interv.type_intervention or '')"/></td>
                    <td><t t-esc="interv.technicien_id.name if interv.technicien_id else 'N/A'"/></td>
                    <td><t t-esc="str(interv.date_debut)[:10] if interv.date_debut else 'N/A'"/></td>
                    <td><t t-esc="'%.1f' % interv.duree_heures"/></td>
                    <td><t t-esc="'{:,.0f}'.format(interv.cout)"/></td>
                    <td><t t-esc="dict(planifie='Planifiée', en_cours='En cours', termine='Terminée', annule='Annulée').get(interv.state, interv.state or '')"/></td>
                </tr>
                </t>
            </tbody>
        </table>
    </t>

    <t t-if="doc.description">
        <h4 class="text-primary mt-3">Description technique</h4>
        <p><t t-esc="doc.description"/></p>
    </t>

    <div class="mt-4 text-muted text-end" style="font-size:11px;">
        <t t-esc="doc.reference"/> — Généré le
        <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y a %H:%M')"/>
    </div>

</div>
</t>
</t>
</t>
</template>
</odoo>
