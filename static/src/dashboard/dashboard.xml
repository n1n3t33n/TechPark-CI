<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="it_parc.Dashboard">
    <div class="o_it_parc_dashboard">

        <!-- ─── CHARGEMENT ───────────────────────────────────────────── -->
        <t t-if="state.loading">
            <div class="o_dashboard_loading">
                <div class="spinner-border text-primary" role="status"/>
                <p class="mt-3 text-muted">Chargement du dashboard...</p>
            </div>
        </t>

        <t t-else="">

            <!-- ─── EN-TÊTE ──────────────────────────────────────────── -->
            <div class="o_dashboard_header">
                <h2>
                    <i class="fa fa-desktop me-2"/>
                    Tableau de bord — Parc Informatique
                </h2>
                <span class="text-muted">TECHPARK CI</span>
            </div>

            <!-- ─── LIGNE 1 : KPIs principaux ────────────────────────── -->
            <div class="o_kpi_row">

                <div class="o_kpi_card o_kpi_blue">
                    <div class="o_kpi_icon"><i class="fa fa-desktop"/></div>
                    <div class="o_kpi_content">
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.total_equipements || 0"/>
                        </div>
                        <div class="o_kpi_label">Total équipements</div>
                    </div>
                </div>

                <div class="o_kpi_card o_kpi_green">
                    <div class="o_kpi_icon"><i class="fa fa-check-circle"/></div>
                    <div class="o_kpi_content">
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.affectes || 0"/>
                        </div>
                        <div class="o_kpi_label">Affectés</div>
                    </div>
                </div>

                <div class="o_kpi_card o_kpi_orange">
                    <div class="o_kpi_icon"><i class="fa fa-wrench"/></div>
                    <div class="o_kpi_content">
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.en_maintenance || 0"/>
                        </div>
                        <div class="o_kpi_label">En maintenance</div>
                    </div>
                </div>

                <div class="o_kpi_card o_kpi_red">
                    <div class="o_kpi_icon"><i class="fa fa-exclamation-triangle"/></div>
                    <div class="o_kpi_content">
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.garanties_expirees || 0"/>
                        </div>
                        <div class="o_kpi_label">Garanties expirées</div>
                    </div>
                </div>

                <div class="o_kpi_card o_kpi_purple">
                    <div class="o_kpi_icon"><i class="fa fa-bell"/></div>
                    <div class="o_kpi_content">
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.alertes_nouvelles || 0"/>
                        </div>
                        <div class="o_kpi_label">Alertes nouvelles</div>
                    </div>
                </div>

                <div class="o_kpi_card o_kpi_teal">
                    <div class="o_kpi_icon"><i class="fa fa-file-text"/></div>
                    <div class="o_kpi_content">
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.contrats_urgents || 0"/>
                        </div>
                        <div class="o_kpi_label">Contrats urgents</div>
                    </div>
                </div>

            </div>

            <!-- ─── LIGNE 2 : KPI coût + interventions mois ──────────── -->
            <div class="o_kpi_row o_kpi_row_wide">

                <div class="o_kpi_card o_kpi_dark o_kpi_wide">
                    <div class="o_kpi_icon"><i class="fa fa-money"/></div>
                    <div class="o_kpi_content">
                        <div class="o_kpi_value o_kpi_value_sm">
                            <t t-esc="formatMontant(state.kpis.cout_total)"/>
                        </div>
                        <div class="o_kpi_label">Coût total maintenance (interventions terminées)</div>
                    </div>
                </div>

                <div class="o_kpi_card o_kpi_indigo o_kpi_wide">
                    <div class="o_kpi_icon"><i class="fa fa-calendar"/></div>
                    <div class="o_kpi_content">
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.interventions_mois || 0"/>
                        </div>
                        <div class="o_kpi_label">Interventions ce mois</div>
                    </div>
                </div>

            </div>

            <!-- ─── LIGNE 3 : Graphiques ──────────────────────────────── -->
            <div class="o_dashboard_graphs">

                <!-- Graphique donut : répartition par catégorie -->
                <div class="o_graph_card">
                    <h4 class="o_graph_title">
                        <i class="fa fa-pie-chart me-2"/>
                        Équipements par catégorie
                    </h4>
                    <div class="o_donut_wrapper">
                        <svg viewBox="0 0 160 160" class="o_donut_svg">
                            <t t-foreach="getDonutSegments()" t-as="seg" t-key="seg_index">
                                <path t-att-d="seg.path"
                                      t-att-fill="seg.couleur"
                                      class="o_donut_segment"/>
                            </t>
                            <!-- Cercle central -->
                            <circle cx="80" cy="80" r="35" fill="white"/>
                            <text x="80" y="76" text-anchor="middle"
                                  class="o_donut_center_label">Total</text>
                            <text x="80" y="92" text-anchor="middle"
                                  class="o_donut_center_value">
                                <t t-esc="state.kpis.total_equipements || 0"/>
                            </text>
                        </svg>
                        <!-- Légende -->
                        <div class="o_donut_legend">
                            <t t-foreach="getDonutSegments()" t-as="seg" t-key="seg_index">
                                <div class="o_legend_item">
                                    <span class="o_legend_dot"
                                          t-attf-style="background:{{seg.couleur}}"/>
                                    <span class="o_legend_text">
                                        <t t-esc="seg.label"/>
                                        (<t t-esc="seg.value"/> — <t t-esc="seg.pct"/>%)
                                    </span>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Graphique barres : interventions 6 derniers mois -->
                <div class="o_graph_card">
                    <h4 class="o_graph_title">
                        <i class="fa fa-bar-chart me-2"/>
                        Interventions — 6 derniers mois
                    </h4>
                    <div class="o_bar_chart">
                        <t t-foreach="state.graphiques.interventions_mois || []"
                           t-as="mois" t-key="mois_index">
                            <div class="o_bar_item">
                                <div class="o_bar_value_label">
                                    <t t-esc="mois.value"/>
                                </div>
                                <div class="o_bar_track">
                                    <div class="o_bar_fill"
                                         t-attf-style="height: {{getLargeurBarre(mois.value, getMaxInterventions())}}"/>
                                </div>
                                <div class="o_bar_label">
                                    <t t-esc="mois.label"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>

            </div>

            <!-- ─── LIGNE 4 : Top équipements + Alertes récentes ─────── -->
            <div class="o_dashboard_tables">

                <!-- Top 5 équipements les plus maintenus -->
                <div class="o_table_card">
                    <h4 class="o_graph_title">
                        <i class="fa fa-trophy me-2"/>
                        Top 5 équipements (maintenances)
                    </h4>
                    <table class="o_dashboard_table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Équipement</th>
                                <th>Réf.</th>
                                <th>Interventions</th>
                                <th>Coût total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.top_equipements.length === 0">
                                <tr>
                                    <td colspan="5" class="text-center text-muted">
                                        Aucune donnée
                                    </td>
                                </tr>
                            </t>
                            <t t-foreach="state.top_equipements"
                               t-as="eq" t-key="eq_index">
                                <tr>
                                    <td><t t-esc="eq_index + 1"/></td>
                                    <td><t t-esc="eq.name"/></td>
                                    <td class="text-muted"><t t-esc="eq.reference"/></td>
                                    <td class="text-center">
                                        <span class="badge badge-warning">
                                            <t t-esc="eq.nb_interventions"/>
                                        </span>
                                    </td>
                                    <td><t t-esc="formatMontant(eq.cout_total)"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Alertes récentes -->
                <div class="o_table_card">
                    <h4 class="o_graph_title">
                        <i class="fa fa-bell me-2"/>
                        Alertes récentes
                    </h4>
                    <table class="o_dashboard_table">
                        <thead>
                            <tr>
                                <th>Alerte</th>
                                <th>Type</th>
                                <th>Échéance</th>
                                <th>Jours</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.alertes_recentes.length === 0">
                                <tr>
                                    <td colspan="4" class="text-center text-muted">
                                        ✅ Aucune alerte nouvelle
                                    </td>
                                </tr>
                            </t>
                            <t t-foreach="state.alertes_recentes"
                               t-as="alerte" t-key="alerte_index">
                                <tr>
                                    <td><t t-esc="alerte.name"/></td>
                                    <td>
                                        <span t-attf-class="badge {{alerte.type_alerte === 'garantie' ? 'badge-info' : 'badge-secondary'}}">
                                            <t t-esc="alerte.type_alerte"/>
                                        </span>
                                    </td>
                                    <td><t t-esc="alerte.date_echeance"/></td>
                                    <td>
                                        <span t-attf-class="badge {{getUrgenceClass(alerte.jours_restants)}}">
                                            <t t-esc="alerte.jours_restants"/> j
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

            </div>

        </t>
    </div>
</t>

</templates>