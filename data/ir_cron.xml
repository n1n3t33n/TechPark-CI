<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_scan_alertes_it_parc" model="ir.cron">
            <field name="name">IT Parc — Scan automatique des alertes</field>
            <field name="model_id" ref="model_it_alerte"/>
            <field name="state">code</field>
            <field name="code">
                model.env['wizard.scan.alertes'].create({
                    'delai_jours': 60
                }).action_scanner()
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>