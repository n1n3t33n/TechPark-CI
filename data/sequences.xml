<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_it_equipement" model="ir.sequence">
            <field name="name">Séquence Équipement IT</field>
            <field name="code">it.equipement</field>
            <field name="prefix">EQ/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

        <record id="seq_it_ticket" model="ir.sequence">
            <field name="name">Séquence Ticket IT</field>
            <field name="code">it.ticket</field>
            <field name="prefix">TCK/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

    </data>
</odoo>
